<?xml version="1.0" encoding="UTF-8"?>

<!-- https://phpunit.readthedocs.io/en/latest/configuration.html -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         colors="true"
         bootstrap="./tests/bootstrap.php"
         cacheResult="false"
>
    <php>
        <ini name="display_errors" value="1" />
        <ini name="error_reporting" value="-1" />
        <server name="APP_ENV" value="test" force="true" />
        <server name="SHELL_VERBOSITY" value="-1" />
        <server name="SYMFONY_PHPUNIT_REMOVE" value="" />
    </php>

    <testsuites>
        <testsuite name="Unit Tests">
            <directory>./src/Spipu/*/tests/Unit</directory>
        </testsuite>
        <testsuite name="Functional Tests">
            <directory>./src/Spipu/*/tests/Functional</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>./src/Spipu/*/src</directory>
        </include>
    </source>

    <coverage>
        <report>
            <clover outputFile="../quality/build/clover.xml"/>
            <html outputDirectory="../quality/build/coverage"/>
        </report>
    </coverage>
</phpunit>
